pipeline {
    agent any

    environment {
        DOCKER_HUB_REPO = 'demishuaccha'
        DOCKER_CREDENTIAL_ID = 'dockerhub-creds'
        BASE_DIR = 'tingesoMS_backend'
        // CORRECCIÓN: Usamos dobles barras para evitar problemas de escape en Windows
        KUBECONFIG = 'C:\\Users\\demis\\.kube\\config'
    }

    stages {
        stage('Login to Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: env.DOCKER_CREDENTIAL_ID, usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        bat "docker login -u %USER% -p %PASS%"
                    }
                }
            }
        }

        stage('Build and Push Microservices') {
            parallel {
                stage('Config Service') { steps { buildAndPush('config-service', 'config-service') } }
                stage('Gateway Service') { steps { buildAndPush('gateway-service', 'gateway-service') } }
                stage('Auth Service') { steps { buildAndPush('tingesoMS_auth', 'tingeso-auth-service') } }
                stage('Income Service') { steps { buildAndPush('tingesoMS_income', 'tingeso-income-service') } }
                stage('Expense Service') { steps { buildAndPush('tingesoMS_expense', 'tingeso-expense-service') } }
                stage('Report Service') { steps { buildAndPush('tingesoMS_report', 'tingeso-report-service') } }
            }
        }

        stage('Cleanup Old Apps') {
            steps {
                script {
                    echo "--- LIMPIEZA PROFUNDA (Heurística 5) ---"

                    // 1. Borramos los despliegues usando sus nombres exactos
                    def deployNames = ['config-service', 'gateway-service', 'tingeso-auth', 'tingeso-income', 'tingeso-expense', 'tingeso-report', 'mysql-service']
                    deployNames.each { name ->
                        bat "kubectl --kubeconfig=%KUBECONFIG% delete deployment ${name} --ignore-not-found=true"
                    }

                    // 2. Borramos servicios (evitando el error de nombre duplicado '-service-service')
                    def serviceNames = ['config-service', 'gateway-service', 'tingeso-auth-service', 'tingeso-income-service', 'tingeso-expense-service', 'tingeso-report-service', 'mysql-service']
                    serviceNames.each { name ->
                        bat "kubectl --kubeconfig=%KUBECONFIG% delete service ${name} --ignore-not-found=true"
                    }

                    // 3. CORRECCIÓN: Borrar el PVC exacto según tu YAML (mysql-pv-claim)
                    echo "Liberando el volumen persistente..."
                    bat "kubectl --kubeconfig=%KUBECONFIG% delete pvc mysql-pv-claim --ignore-not-found=true"

                    // 4. Limpiar ConfigMaps
                    bat "kubectl --kubeconfig=%KUBECONFIG% delete configmap config-repo --ignore-not-found=true"
                }
            }
        }

        stage('Deploy Infrastructure') {
            steps {
                script {
                    echo "--- Recreando Infraestructura ---"
                    bat "kubectl --kubeconfig=%KUBECONFIG% create configmap config-repo --from-file=%BASE_DIR%/config-data"
                    bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/mysql-pv.yml"
                    bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/mysql-secrets.yml"
                    bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/mysql-init-script.yml"
                    bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/mysql-deployment.yml"

                    echo "Esperando a MySQL..."
                    bat "kubectl --kubeconfig=%KUBECONFIG% wait --for=condition=ready pod -l app=mysql-db --timeout=120s"
                }
            }
        }

        stage('Deploy Core Services') {
            steps {
                script {
                    echo "--- Levantando Config Server ---"
                    bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/config-deployment.yml"
                    bat "kubectl --kubeconfig=%KUBECONFIG% wait --for=condition=ready pod -l app=config-service --timeout=120s"
                }
            }
        }

        stage('Deploy Business Services') {
            steps {
                script {
                    echo "--- Desplegando Lógica de Negocio ---"
                    def serviceFiles = ['auth', 'income', 'expense', 'report', 'gateway']
                    serviceFiles.each { file ->
                        bat "kubectl --kubeconfig=%KUBECONFIG% apply -f %BASE_DIR%/k8s/${file}-deployment.yml"
                    }
                }
            }
        }
    }

    post {
        always {
            script { bat 'docker logout' }
        }
        success {
            echo "¡Pipeline exitoso! Sistema desplegado."
        }
    }
}

def buildAndPush(folderName, imageName) {
    script {
        def fullName = "${env.DOCKER_HUB_REPO}/${imageName}:latest"
        def fullPath = "${env.BASE_DIR}/${folderName}"
        dir(fullPath) {
            bat "mvn clean package -DskipTests"
            bat "docker build -t ${fullName} ."
            bat "docker push ${fullName}"
        }
    }
}